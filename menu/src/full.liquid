{%- comment -%}
  `menus` is produced by transform.js (an array of { vendor, date, data }).
  Fall back to `data` in case the runtime exposes it under that name.
{%- endcomment -%}
{%- assign vendor_list = menus -%}
{%- if vendor_list == nil or vendor_list == empty -%}{%- assign vendor_list = data -%}{%- endif -%}

<div class="gap--small grid overflow--hidden layout" style="grid-template-columns: auto 150px 1fr; place-content: center;">
  {%- assign first_vendor = true -%}
  {%- for menu in vendor_list -%}
    {%- assign stations = menu.data -%}
    {%- unless stations == nil or stations == empty -%}

      {%- comment -%} Short vendor label from the vendor keyname. {%- endcomment -%}
      {%- case menu.vendor -%}
        {%- when "b3espresso" -%}{%- assign vlabel = "3" -%}
        {%- when "b7espresso" -%}{%- assign vlabel = "7" -%}
        {%- when "cafe92" -%}{%- assign vlabel = "92" -%}
        {%- when "cafe109" -%}{%- assign vlabel = "109" -%}
        {%- when "cafe121" -%}{%- assign vlabel = "121" -%}
        {%- when "cafe16" -%}{%- assign vlabel = "16" -%}
        {%- when "cafe25" -%}{%- assign vlabel = "25" -%}
        {%- when "cafe31" -%}{%- assign vlabel = "31" -%}
        {%- when "in-gredients" -%}{%- assign vlabel = "34in.gr" -%}
        {%- when "cafe34" -%}{%- assign vlabel = "34" -%}
        {%- when "cafe36" -%}{%- assign vlabel = "36" -%}
        {%- when "cafe37" -%}{%- assign vlabel = "37" -%}
        {%- when "cafe40-41" -%}{%- assign vlabel = "40/41" -%}
        {%- when "cafe43" -%}{%- assign vlabel = "43" -%}
        {%- when "cafe50" -%}{%- assign vlabel = "50" -%}
        {%- when "cafe83" -%}{%- assign vlabel = "83" -%}
        {%- when "cafe86" -%}{%- assign vlabel = "86" -%}
        {%- when "cafe99" -%}{%- assign vlabel = "99" -%}
        {%- when "cafemille" -%}{%- assign vlabel = "Mil.E" -%}
        {%- when "caferedwest" -%}{%- assign vlabel = "RedWest" -%}
        {%- when "cafertc5" -%}{%- assign vlabel = "RTC" -%}
        {%- when "cafestudioh" -%}{%- assign vlabel = "Std.H" -%}
        {%- when "boardwalk" -%}{%- assign vlabel = "Com.Brdwlk" -%}
        {%- when "bowlna" -%}{%- assign vlabel = "Com.Bowlna" -%}
        {%- when "chandys" -%}{%- assign vlabel = "Com.Chndy’s" -%}
        {%- when "himalaya" -%}{%- assign vlabel = "Com.Hmly" -%}
        {%- when "hometown" -%}{%- assign vlabel = "Com.Hmtn" -%}
        {%- when "justpoke" -%}{%- assign vlabel = "Com.Poké" -%}
        {%- when "mayas" -%}{%- assign vlabel = "Com.Maya’s + Pita" -%}
        {%- when "s-wich" -%}{%- assign vlabel = "Com.S’wich" -%}
        {%- when "typhoon" -%}{%- assign vlabel = "Com.Typhn!" -%}
        {%- when "foodhall4" -%}{%- assign vlabel = "4" -%}
        {%- when "fh4boonboona" -%}{%- assign vlabel = "4Boon" -%}
        {%- when "fh4jacksbbq" -%}{%- assign vlabel = "4BBQ" -%}
        {%- when "fh4joesburger" -%}{%- assign vlabel = "4Burgers" -%}
        {%- when "fh4justpoke" -%}{%- assign vlabel = "4Poké" -%}
        {%- when "fh4mila" -%}{%- assign vlabel = "4MiLa" -%}
        {%- when "fh4papparepas" -%}{%- assign vlabel = "4Papa" -%}
        {%- when "foodhall6" -%}{%- assign vlabel = "6" -%}
        {%- when "bobae" -%}{%- assign vlabel = "6Bobae" -%}
        {%- when "craft75" -%}{%- assign vlabel = "6Craft75" -%}
        {%- when "dote" -%}{%- assign vlabel = "6Dote" -%}
        {%- when "l-experience" -%}{%- assign vlabel = "6L’Exp" -%}
        {%- when "pinkabella" -%}{%- assign vlabel = "6Pinka" -%}
        {%- when "foodhall9" -%}{%- assign vlabel = "9" -%}
        {%- when "fh9bigchicken" -%}{%- assign vlabel = "9Chx" -%}
        {%- when "one-esterra" -%}{%- assign vlabel = "1Est" -%}
        {%- when "dote-rts" -%}{%- assign vlabel = "RTSDote" -%}
        {%- when "studioa" -%}{%- assign vlabel = "Std.A" -%}
        {%- when "studiod" -%}{%- assign vlabel = "Std.D" -%}
        {%- else -%}{%- assign vlabel = menu.vendor -%}
      {%- endcase -%}

      {%- assign vendor_shown = false -%}

      {%- unless first_vendor -%}
        <div class="divider col--span-3"></div>
      {%- endunless -%}
      {%- assign first_vendor = false -%}

      {%- comment -%} Pass 1: traveling stations first, then the rest. {%- endcomment -%}
      {%- for pass in (1..2) -%}
        {%- for st in stations -%}
          {%- if pass == 1 -%}
            {%- unless st.uniqueness.isTraveling -%}{%- continue -%}{%- endunless -%}
          {%- else -%}
            {%- if st.uniqueness.isTraveling -%}{%- continue -%}{%- endif -%}
          {%- endif -%}

          {%- assign item_count = 0 -%}
          {%- for pair in st.menu -%}{%- assign item_count = item_count | plus: pair[1].size -%}{%- endfor -%}
          {%- if item_count == 0 -%}{%- continue -%}{%- endif -%}

          <div class="col--span-3" style="display: grid; grid-template-columns: subgrid; column-gap: 12px; align-items: start; justify-items: start;">
            <div class="no-shrink">
              {%- unless vendor_shown -%}
                <span class="text--gray-30 label label--small">{{ vlabel }}</span>
                {%- assign vendor_shown = true -%}
              {%- endunless -%}
            </div>
            <div class="no-shrink">
              <div class="flex flex--center-y flex--row gap--xsmall">
                <span class="title title--small">
                  {{ st.name }}
                  {%- if st.uniqueness.isTraveling -%}
                    <iconify-icon icon="mdi:airplane" class="text-[18px]" style="display: inline-block; translate: 0 2px;"></iconify-icon>
                  {%- endif -%}
                </span>
              </div>
            </div>

            <div class="flex flex--center-y flex--left flex--row flex--wrap gap--small" style="justify-self: stretch;">
              {%- for pair in st.menu -%}
                {%- assign items = pair[1] -%}
                {%- if items.size > 0 -%}
                  <span class="text--gray-30 label label--small">{{ pair[0] }}</span>
                  {%- for item in items -%}
                    <span class="label--outline label label--small">{{ item.name }}</span>
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}

    {%- endunless -%}
  {%- endfor -%}
</div>

<div class="title_bar">
  <iconify-icon icon="mdi:silverware-fork-knife" class="image image-stroke" style="font-size: var(--title-bar-image-height);"></iconify-icon>
  <span class="title">{{ trmnl.plugin_settings.instance_name | default: "Menu" }}</span>
  <span class="instance">{{ dateLabel | default: "Today" }}</span>
</div>

<script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>