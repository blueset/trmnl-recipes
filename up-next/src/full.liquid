<script id="up-data" type="application/json">{{ plugin_instance | json }}</script>
<script>window.UP_DEBUG_NOW = {{ debug_now | json }};</script>

<style>
  #up-root { height: 100%; }
  #up-root .up-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 16px;
    height: 100%;
    box-sizing: border-box;
  }
  #up-root .up-panel {
    padding: 14px 16px;
    box-sizing: border-box;
    overflow: hidden;
    min-height: 0;
  }
  #up-root .up-events { display: flex; flex-direction: column; gap: 10px; }
  #up-root .up-timeline { padding: 10px 8px 8px 10px; display: flex; flex-direction: column; gap: 8px; }

  /* Sections & cards */
  #up-root .up-sec { display: flex; flex-direction: column; gap: 6px; }
  #up-root .up-sec + .up-sec { border-top: 1px solid currentColor; padding-top: 10px; }
  #up-root .up-cards { display: flex; flex-direction: column; gap: 10px; }
  #up-root .up-cards.up-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 16px; }
  #up-root .up-cards.up-cols > .up-card + .up-card {
    border-left: 1px solid currentColor; padding-left: 14px;
  }

  /* Dividers between neighboring ongoing events */
  #up-root .up-sec--ongoing > .up-card + .up-cards {
    border-top: 1px solid currentColor; padding-top: 10px;
  }
  #up-root .up-sec--ongoing .up-cards:not(.up-cols) > .up-card + .up-card {
    border-top: 1px solid currentColor; padding-top: 10px;
  }

  /* Section sizing — the ongoing section (always first) or the first section fills the panel */
  #up-root .up-events > .up-sec:first-of-type { flex: 1 1 0; }
  #up-root .up-sec--ongoing > .up-card,
  #up-root .up-sec--ongoing > .up-cards { flex: 1 1 0; }
  #up-root .up-sec--ongoing .up-cards > .up-card { flex: 1 1 0; }

  #up-root .up-card { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  #up-root .up-time { font-size: 17px; }
  #up-root .up-title {
    line-height: 1.04;
    text-wrap: balance;
    display: -webkit-box; -webkit-box-orient: vertical; overflow: hidden;
  }
  #up-root .up-loc {
    display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 1; overflow: hidden;
  }
  #up-root .up-desc {
    display: -webkit-box; -webkit-box-orient: vertical; overflow: hidden;
  }

  /* Primary (largest) card */
  #up-root .up-card--primary .up-time { font-size: 19px; }
  #up-root .up-card--primary .up-title { font-size: 44px; -webkit-line-clamp: 3; margin: 2px 0; }
  #up-root .up-card--primary .up-loc { font-size: 22px; -webkit-line-clamp: 5; }
  #up-root .up-card--primary .up-desc { font-size: 16px; -webkit-line-clamp: 5; }

  /* Compact card */
  #up-root .up-card--compact .up-time { font-size: 14px; }
  #up-root .up-card--compact .up-title { font-size: 26px; -webkit-line-clamp: 3; }
  #up-root .up-card--compact .up-loc { font-size: 15px; }
  #up-root .up-card--compact .up-desc { font-size: 13px; -webkit-line-clamp: 5; }

  /* Density tiers applied on the events panel */
  #up-root[data-density="2"] .up-card--primary .up-title { font-size: 52px; -webkit-line-clamp: 6; }
  #up-root[data-density="2"] .up-card--primary .up-desc  { -webkit-line-clamp: 6; }
  #up-root[data-density="3"] .up-card--primary .up-title { font-size: 40px; }
  #up-root[data-density="3"] .up-card--primary .up-desc  { -webkit-line-clamp: 3; }
  #up-root[data-density="4"] .up-card--primary .up-title { font-size: 34px; -webkit-line-clamp: 3; }
  #up-root[data-density="4"] .up-card--primary .up-desc  { -webkit-line-clamp: 3; }

  /* All-day chips */
  #up-root .up-allday { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 4px; }

  /* Inline Teams icon inside the location field */
  #up-root .up-teams-icon {
    width: 1.05em; height: 1.05em; vertical-align: -0.18em;
    fill: currentColor; margin: 0 1px;
  }

  #up-root .up-empty { margin: auto; }

  /* FullCalendar grayscale theming for e-ink */
  #up-cal { flex: 1 1 auto; min-height: 0; }
  #up-cal.fc {
    height: 100%; 
    font-family: var(--font-base-font-family);
    --fc-page-bg-color: transparent;
    --fc-neutral-bg-color: transparent;
    --fc-today-bg-color: transparent;
    --fc-now-indicator-color: #000;
    --fc-border-color: rgba(0,0,0,.35);
  }
  #up-cal .fc-day-today { background: transparent !important; }
  #up-cal .fc-timegrid-col-bg .fc-non-business { background: transparent; }
  #up-cal .fc-theme-standard td,
  #up-cal .fc-theme-standard th,
  #up-cal .fc-scrollgrid { border-color: rgba(0,0,0,.35); }
  #up-cal .fc-timegrid-slot { height: auto; }
  #up-cal .fc-timegrid-slot-label-cushion { font-size: 12px; font-weight: 700; }
  #up-cal .fc-timegrid-axis-cushion { font-size: 10px; }
  #up-cal .fc-timegrid-event-harness { overflow: hidden; }
  #up-cal .fc-event,
  #up-cal .fc-timegrid-event {
    background: #fff;
    border: 1.5px solid currentColor; border-radius: 3px;
    box-shadow: none; color: inherit; overflow: hidden;
    border-color: white;
    background: black;
    color: white;
  }
  #up-cal .fc-event-main { color: inherit; padding: 1px 4px; overflow: hidden; }
  #up-cal .fc-up-title { font-weight: 800; font-size: 11px; line-height: 1.2;
    display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
  #up-cal .fc-up-time { font-size: 9px; font-weight: 700;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  #up-cal .fc-up-ev--tentative {
    border-style: dashed;
    border-width: 1.5px;
    border-color: black;
    background: var(--bg-gray-75-color);
    color: black;
  }
  #up-cal .fc-timegrid-now-indicator-line { border-color: #000; border-width: 2px; }
  #up-cal .fc-timegrid-now-indicator-arrow { border-color: #000; }
  #up-cal .fc-scroller { overflow: hidden !important; }

  .trmnl .screen--4bit .title.font--bold {
    --title-font-weight: 800;
  }
</style>

<div class="layout">
  <div id="up-root">
    <div class="up-grid">
      <section class="up-panel up-events" id="up-events">
        <div class="up-empty">Loading…</div>
      </section>
      <section class="up-panel up-timeline">
        <div id="up-cal"></div>
      </section>
    </div>
  </div>
</div>

<div class="title_bar">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="image image-stroke">
	<path d="M0 0h48v48H0z" fill="none" />
	<path fill="currentColor" d="M15.5 26a2.5 2.5 0 1 0 0-5a2.5 2.5 0 0 0 0 5m11-2.5a2.5 2.5 0 1 1-5 0a2.5 2.5 0 0 1 5 0m6 2.5a2.5 2.5 0 1 0 0-5a2.5 2.5 0 0 0 0 5M18 31.5a2.5 2.5 0 1 1-5 0a2.5 2.5 0 0 1 5 0m6 2.5a2.5 2.5 0 1 0 0-5a2.5 2.5 0 0 0 0 5M6 12.25A6.25 6.25 0 0 1 12.25 6h23.5A6.25 6.25 0 0 1 42 12.25v23.5A6.25 6.25 0 0 1 35.75 42h-23.5A6.25 6.25 0 0 1 6 35.75zm6.25-3.75a3.75 3.75 0 0 0-3.75 3.75V14h31v-1.75a3.75 3.75 0 0 0-3.75-3.75zM8.5 35.75a3.75 3.75 0 0 0 3.75 3.75h23.5a3.75 3.75 0 0 0 3.75-3.75V16.5h-31z" />
</svg>

  <span class="title">{{ trmnl.plugin_settings.instance_name | default: "Up next" }}</span>
  <span class="instance" id="up-clock"></span>
</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
<script>
(function () {
  "use strict";

  // ── Load data ──────────────────────────────────────────────────────────
  var data;
  try { 
    data = JSON.parse(document.getElementById("up-data").textContent || "{}");
    console.log("Calendar data loaded", data);
  } catch (e) { 
    console.error("Failed to parse calendar data", e);
    data = {};
  }
  var events = Array.isArray(data.events) ? data.events : [];
  var is12h = (data.time_format === "12_hrs");

  // ── Timezone offset (minutes) from the calendar payload ────────────────
  function parseOffsetMin(s) {
    var m = /([+-])(\d{2}):(\d{2})$/.exec(s || "");
    if (!m) return -new Date().getTimezoneOffset(); // fall back to local
    var sign = m[1] === "-" ? -1 : 1;
    return sign * (parseInt(m[2], 10) * 60 + parseInt(m[3], 10));
  }
  var offMin = parseOffsetMin(data.today_in_tz);
  var offMs = offMin * 60000;
  function offLabel() {
    var a = Math.abs(offMin), sign = offMin < 0 ? "-" : "+";
    return sign + pad(Math.floor(a / 60)) + ":" + pad(a % 60);
  }

  // epoch(ms) -> Date whose UTC fields equal the wall-clock in the cal tz
  function wall(epoch) { return new Date(epoch + offMs); }
  function pad(n) { return (n < 10 ? "0" : "") + n; }
  function naiveISO(epoch) {
    var w = wall(epoch);
    return w.getUTCFullYear() + "-" + pad(w.getUTCMonth() + 1) + "-" + pad(w.getUTCDate()) +
      "T" + pad(w.getUTCHours()) + ":" + pad(w.getUTCMinutes()) + ":" + pad(w.getUTCSeconds());
  }
  function dayKey(epoch) { return naiveISO(epoch).slice(0, 10); }
  function fmtTime(epoch) {
    var w = wall(epoch), h = w.getUTCHours(), mi = w.getUTCMinutes();
    if (is12h) {
      var ap = h < 12 ? "AM" : "PM", h12 = h % 12; if (h12 === 0) h12 = 12;
      return h12 + ":" + pad(mi) + " " + ap;
    }
    return pad(h) + ":" + pad(mi);
  }

  var WEEKDAYS = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
  var MONTHS = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  function dayLabel(epoch) {
    if (dayKey(epoch) === today) return "Today";
    var w = wall(epoch);
    return WEEKDAYS[w.getUTCDay()] + ", " + MONTHS[w.getUTCMonth()] + " " + w.getUTCDate();
  }

  // ── Resolve "now" ──────────────────────────────────────────────────────
  var nowEpoch;
  if (window.UP_DEBUG_NOW) {
    var p = Date.parse(window.UP_DEBUG_NOW);
    nowEpoch = isNaN(p) ? Date.now() : p;
  } else {
    nowEpoch = Date.now();
  }
  var today = dayKey(nowEpoch);

  // ── Description cleanup ────────────────────────────────────────────────
  var TEAMS_SVG = '<svg class="up-teams-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="currentColor"><path d="M21.75 18c1.82 0 3.45.77 4.6 2.01l.15-.01h7.25C37.2 20 40 22.8 40 26.25v8.5c0 4-3.25 7.25-7.25 7.25h-14.5c-2.83 0-5.4-1.15-7.25-3H7.25A3.25 3.25 0 0 1 4 35.75v-9.5C4 24.45 5.46 23 7.25 23h.88c.57-2.85 3.1-5 6.12-5zm-7.5 2.5a3.75 3.75 0 0 0-3.54 2.5h6.04c1.8 0 3.25 1.46 3.25 3.25v9.5c0 1.8-1.45 3.25-3.25 3.25h-1.24q1.29.49 2.74.5h9.03a7.2 7.2 0 0 1-1.78-4.75v-10.5a3.75 3.75 0 0 0-3.75-3.75zm13.5 2q.25.84.25 1.75v10.5a4.75 4.75 0 1 0 9.5 0v-8.5a3.75 3.75 0 0 0-3.75-3.75zM8.52 28.1h2.45v7.47h2.06v-7.46h2.45v-1.68H8.52zM32.26 8A5 5 0 0 1 37 13v.26A5 5 0 0 1 32 18h-.26a5 5 0 0 1-4.73-4.74L27 13a5 5 0 0 1 5-5zM18 4a6 6 0 1 1 0 12 6 6 0 0 1 0-12m14 6.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5m-14-4a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7"/></svg>';
  function escapeHTML(s) {
    var d = document.createElement("div"); d.textContent = String(s); return d.innerHTML;
  }
  function locHTML(s) {
    return escapeHTML(s).replace(/Microsoft Teams Meeting/g, TEAMS_SVG);
  }

  var decoder = document.createElement("textarea");
  function cleanText(s) {
    if (!s) return "";
    s = String(s).split(/_{5,}/)[0];        // drop Teams/meeting boilerplate
    decoder.innerHTML = s;                    // decode HTML entities
    s = decoder.value;
    s = s.replace(/https?:\/\/\S+/g, " ");   // strip raw URLs
    s = s.replace(/\s+/g, " ").trim();
    return s;
  }

  // ── Build timed + all-day lists ────────────────────────────────────────
  var timedAll = [], allDay = [];
  events.forEach(function (ev) {
    if (ev.all_day) {
      var ad = Date.parse((ev.start_full || ev.start) + "T00:00:00" + offLabel());
      if (!isNaN(ad) && dayKey(ad) === today) allDay.push(ev);
      return;
    }
    var s = Date.parse(ev.start_full), e = Date.parse(ev.end_full);
    if (isNaN(s) || isNaN(e)) return;
    timedAll.push({ summary: ev.summary || "(no title)", location: ev.location || "",
      desc: cleanText(ev.description), s: s, e: e, status: ev.status });
  });
  timedAll.sort(function (a, b) { return a.s - b.s || a.e - b.e; });

  // Today's events drive the timeline + ongoing detection; upcoming spans all days.
  var timed = timedAll.filter(function (t) { return dayKey(t.s) === today; });
  var ongoing = timed.filter(function (t) { return t.s <= nowEpoch && nowEpoch < t.e; });
  var upcoming = timedAll.filter(function (t) { return t.s > nowEpoch; });

  // ── Events view selection ──────────────────────────────────────────────
  var nUp = ongoing.length === 0 ? 2 : 1;
  var sections = [];
  if (ongoing.length) {
    sections.push({ label: "Ongoing", items: ongoing, ongoing: true });
    if (upcoming.length) sections.push({ label: "Up next", items: upcoming.slice(0, nUp) });
  } else if (upcoming.length) {
    sections.push({ label: "Up next", items: upcoming.slice(0, 1) });
    if (upcoming.length > 1) sections.push({ label: "Following", items: upcoming.slice(1, 2) });
  }

  // ── Render events view ─────────────────────────────────────────────────
  var root = document.getElementById("up-root");
  var host = document.getElementById("up-events");
  host.innerHTML = "";

  if (allDay.length) {
    var chips = document.createElement("div");
    chips.className = "up-allday";
    allDay.forEach(function (a) {
      var c = document.createElement("span");
      c.className = "up-chip label label--outline"; c.textContent = a.summary || "";
      chips.appendChild(c);
    });
    var timeline = document.querySelector(".up-timeline");
    timeline.insertBefore(chips, timeline.firstChild);
  }

  var totalCards = sections.reduce(function (n, s) { return n + s.items.length; }, 0);
  root.setAttribute("data-density", String(Math.min(4, Math.max(2, totalCards))));

  if (totalCards === 0) {
    var empty = document.createElement("div");
    empty.className = "up-empty label label--gray label--large";
    empty.textContent = "Nothing scheduled";
    host.appendChild(empty);
  }

  var cardIndex = 0;
  function makeCard(it, primary) {
    var card = document.createElement("div");
    card.className = "up-card " + (primary ? "up-card--primary" : "up-card--compact");
    var t = document.createElement("div");
    t.className = "up-time label text--bold"; t.textContent = dayLabel(it.s) + " " + fmtTime(it.s) + " \u2013 " + fmtTime(it.e);
    card.appendChild(t);
    var ti = document.createElement("div");
    ti.className = "up-title title font--bold"; ti.textContent = it.summary; card.appendChild(ti);
    if (it.location) {
      var l = document.createElement("div");
      l.className = "up-loc label label--gray"; l.innerHTML = locHTML(it.location); card.appendChild(l);
    }
    if (it.desc) {
      var d = document.createElement("div");
      d.className = "up-desc description"; d.textContent = it.desc; card.appendChild(d);
    }
    return card;
  }

  sections.forEach(function (sec) {
    var s = document.createElement("div");
    s.className = "up-sec" + (sec.ongoing ? " up-sec--ongoing" : "");
    var lab = document.createElement("div");
    lab.className = "up-sec-label label label--filled";
    lab.style.alignSelf = "start";
    lab.textContent = sec.label;
    s.appendChild(lab);

    // First item of the section: primary only if it's the very first card overall.
    var primaryItem = sec.items[0];
    var primary = (cardIndex === 0);
    s.appendChild(makeCard(primaryItem, primary));
    cardIndex++;

    var rest = sec.items.slice(1);
    if (rest.length) {
      var wrap = document.createElement("div");
      wrap.className = "up-cards" + (rest.length >= 2 ? " up-cols" : "");
      rest.forEach(function (it) { wrap.appendChild(makeCard(it, false)); cardIndex++; });
      s.appendChild(wrap);
    }
    host.appendChild(s);
  });

  // Shrink-to-fit guard for the events panel (idempotent — safe to re-run)
  function fit() {
    var els = host.querySelectorAll(".up-title, .up-time, .up-loc, .up-desc");
    els.forEach(function (el) {
      if (!el.dataset.base) el.dataset.base = parseFloat(getComputedStyle(el).fontSize);
      el.style.fontSize = el.dataset.base + "px"; // reset before measuring
    });
    var scale = 1;
    for (var i = 0; i < 6 && host.scrollHeight > host.clientHeight + 1 && scale > 0.6; i++) {
      scale -= 0.07;
      els.forEach(function (el) {
        el.style.fontSize = (parseFloat(el.dataset.base) * scale) + "px";
      });
    }
  }
  fit();

  // ── Title-bar clock ────────────────────────────────────────────────────
  document.getElementById("up-clock").textContent = `Refreshed on ` + fmtTime(nowEpoch);

  // ── Timeline bounds ────────────────────────────────────────────────────
  function floorHour(epoch) { var w = wall(epoch); return w.getUTCHours(); }
  function ceilHour(epoch) { var w = wall(epoch); return w.getUTCHours() + (w.getUTCMinutes() || w.getUTCSeconds() ? 1 : 0); }

  var startCandidates = [nowEpoch].concat(timed.map(function (t) { return t.s; }));
  var minStartEpoch = Math.min.apply(null, startCandidates);
  var endCandidates = [nowEpoch].concat(timed.map(function (t) { return t.e; }));
  var maxEndEpoch = Math.max.apply(null, endCandidates);

  var minH = Math.max(0, floorHour(minStartEpoch));
  var maxH = Math.min(24, Math.max(minH + 1, ceilHour(maxEndEpoch)));
  function slot(h) { return pad(h) + ":00:00"; }

  // ── FullCalendar timeline ──────────────────────────────────────────────
  var fcEvents = timed.map(function (t) {
    return {
      title: t.summary,
      start: naiveISO(t.s),
      end: naiveISO(t.e),
      classNames: t.status === "tentative" ? ["fc-up-ev--tentative"] : [],
      extendedProps: { timeText: fmtTime(t.s) + " – " + fmtTime(t.e) }
    };
  });

  var calEl = document.getElementById("up-cal");
  var cal = null;
  if (window.FullCalendar && calEl) {
    cal = new FullCalendar.Calendar(calEl, {
      initialView: "timeGridDay",
      initialDate: today,
      timeZone: "local",
      headerToolbar: false,
      dayHeaders: false,
      allDaySlot: false,
      nowIndicator: true,
      now: naiveISO(nowEpoch),
      slotMinTime: slot(minH),
      slotMaxTime: slot(maxH),
      slotDuration: "01:00:00",
      slotLabelInterval: "01:00:00",
      slotLabelFormat: { hour: "numeric", minute: "2-digit", hour12: is12h, omitZeroMinute: true, meridiem: is12h ? "short" : false },
      expandRows: true,
      height: "100%",
      eventOverlap: true,
      slotEventOverlap: true,
      events: fcEvents,
      eventContent: function (arg) {
        var w = document.createElement("div");
        var tm = document.createElement("div");
        tm.className = "fc-up-time"; tm.textContent = arg.event.extendedProps.timeText || "";
        var ti = document.createElement("div");
        ti.className = "fc-up-title"; ti.textContent = arg.event.title;
        w.appendChild(tm); w.appendChild(ti);
        return { domNodes: [w] };
      }
    });
    cal.render();
  }

  // ── Re-measure on font load & container resize ───────────────────────────
  // Initial measurement happens above once the DOM is built. Re-run whenever a
  // size input changes: web fonts finishing loading can change text metrics, and
  // the container can be resized (device rotation, layout reflow).
  function remeasure() {
    fit();
    if (cal) cal.updateSize();
  }
  var remeasureRaf = null;
  function scheduleRemeasure() {
    if (remeasureRaf) cancelAnimationFrame(remeasureRaf);
    remeasureRaf = requestAnimationFrame(remeasure);
  }

  // Web fonts loaded
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(scheduleRemeasure);
  }

  // Container dimensions changed
  if (window.ResizeObserver) {
    var firstRO = true;
    var ro = new ResizeObserver(function () {
      if (firstRO) { firstRO = false; return; } // skip the initial observe callback
      scheduleRemeasure();
    });
    ro.observe(root);
  }
})();
</script>