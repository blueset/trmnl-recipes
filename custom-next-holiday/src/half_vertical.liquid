<div style="display: contents;" lang="{{ trmnl.user.locale | escape }}" data-t-data="{{ custom_next_holiday_strings | json | escape }}" data-holidays="{{ trmnl.plugin_settings.custom_fields_values.holidays | default: "[]" | escape }}">
  <div class="layout layout--row" data-tz="{{ trmnl.user.time_zone_iana }}">
    <div class="flex flex-col justify-center w-full h-full grow">
      <div class="place-content-center w-full h-[30cqw] port:h-[50cqw] text-center text-start grow-0" style="container-type: size;">
        <iconify-icon icon="mdi:home" class="text-[100cqmin] image-dither"></iconify-icon>
      </div>
      <div class="place-content-center w-full grow-0" data-text-container>
      </div>
    </div>
  </div>

  <div class="title_bar">
    <iconify-icon icon="fluent:calendar-star-24-regular" class="text-[24px] image image-stroke image-dither"></iconify-icon>
    <span class="title" data-t="next_holiday">Next holiday</span>
    <span class="instance">{{ trmnl.plugin_settings.instance_name }}</span>
  </div>
</div>
{% render "common", trmnl: trmnl, 
  mainValueClass: "value--large lg:value--xxlarge portrait:value--base lg:portrait:value--xlarge",
  mainLabelClass: "value--base lg:value--large portrait:value--small lg:portrait:value--base"
%}