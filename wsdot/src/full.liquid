{% if view == 'travelTime' %}
  {%
    render 'trafficTime',
    trafficTime: trafficTime,
    trmnl: trmnl
  %}
{% elsif view == 'alert' %}
  {%
    render 'alerts',
    alerts: alerts,
    trmnl: trmnl
  %}
{% elsif view == 'camera' %}
  {%
    render 'cameras',
    cameras: cameras,
    cameraTitleClass: 'title title--small h-[2lh] content-end',
    trmnl: trmnl
  %}
{% endif %}

<style type="text/css" id="tailwind-trmnl-generated">
/*! tailwindcss v4.3.2 | MIT License | https://tailwindcss.com */
@layer theme, base, components, utilities;
@layer utilities {
  .h-\[2lh\] {
    height: 2lh;
  }
  .content-end {
    align-content: flex-end;
  }
}
</style>
